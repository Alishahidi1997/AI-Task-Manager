# Database — omit for default SQLite (db.sqlite3)
# DATABASE_URL=postgresql+psycopg://smarttask:smarttask@localhost:5432/smarttask

JWT_SECRET_KEY=change-me-in-production
# APP_ENV=production
# DEMO_MODE=false
# HTTP_LOG_JSON=true
OPENAI_API_KEY=

# Phase 3.7 — workspace limits (0 = unlimited)
# WORKSPACE_MAX_TASKS_PER_USER=500
# WORKSPACE_MAX_OPEN_TASKS_PER_USER=100
# WORKSPACE_AI_REQUESTS_PER_HOUR=0

# Outbound webhooks on successful orchestration (chat/Slack)
# WEBHOOK_URL=https://your-app.example/hooks/smart-task
# WEBHOOK_SECRET=change-me

# RabbitMQ — enables LLM job queue for /chat and async Slack
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# LLM_QUEUE_ENABLED=true

# REDIS_URL=redis://localhost:6379/0
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_CHAT_PER_MINUTE=30
# RATE_LIMIT_SLACK_PER_MINUTE=60
# RATE_LIMIT_WINDOW_SECONDS=60
# INSIGHTS_SNAPSHOT_CACHE_SECONDS=60
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=
